{
  "name": "amlak-web",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "description": "Amlak Web - Real Estate Management System v2.0",
  "author": "Mohammad Sajjadi (mmcode)",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently \"npm run dev\" \"cd Backend && npm run dev\"",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "backend:dev": "cd Backend && npm run dev",
    "backend:start": "cd Backend && npm start",
    "create:admin": "cd Backend && node scripts/createAdmin.js",
    "seed": "cd Backend && node scripts/seedDatabase.js",
    "download:images": "node download-images.cjs",
    "setup:full": "npm run install:all && npm run download:images && npm run seed && npm run create:admin",
    "install:all": "npm install && cd Backend && npm install",
    "build:all": "npm run build && cd Backend && npm install --production",
    "deploy": "node deploy.js",
    "build:github": "NODE_ENV=production npm run build",
    "clean": "rimraf dist node_modules/.vite",
    "setup": "npm run install:all && npm run create:admin",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "axios": "^1.11.0",
    "chart.js": "^4.5.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.577.0",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "vazirmatn": "^33.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^8.2.2",
    "cssnano": "^7.0.6",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "jsdom": "^29.0.0",
    "postcss": "^8.5.6",
    "rimraf": "^5.0.10",
    "tailwindcss": "^3.4.17",
    "terser": "^5.43.1",
    "vite": "^7.0.4",
    "vitest": "^4.1.0"
  },
  "keywords": [
    "real-estate",
    "property-management",
    "react",
    "nodejs",
    "mysql",
    "pwa",
    "responsive",
    "rtl",
    "persian",
    "iran"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/MHDcoderC/amlak-web.git"
  },
  "bugs": {
    "url": "https://github.com/MHDcoderC/amlak-web/issues"
  },
  "homepage": "https://amlak.mmdcode.top/"
}
