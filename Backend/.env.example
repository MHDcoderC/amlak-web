# ==========================================
# تنظیمات دیتابیس MongoDB
# ==========================================

# آدرس اتصال MongoDB
# برای MongoDB لوکال:
MONGODB_URI=mongodb://localhost:27017/amlak_db

# سرور با احراز هویت (حتماً USER و PASS را بگذارید؛ در غیر این صورت delete/write خطا می‌دهد):
# MONGODB_URI=mongodb://USERNAME:PASSWORD@HOST:27017/amlak_db?authSource=admin
# اگر authSource را جدا می‌خواهی:
# MONGODB_AUTH_SOURCE=admin

# برای MongoDB Atlas (کلود):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/amlak_db?retryWrites=true&w=majority

# ==========================================
# تنظیمات JWT (احراز هویت)
# ==========================================

# کلید مخفی برای توکن‌ها (یه رشته طولانی و تصادفی بذار)
JWT_SECRET=your_super_secret_key_here_change_this_in_production

# مدت زمان انقضای توکن (مثلاً: 7d = 7 روز, 24h = 24 ساعت)
JWT_EXPIRE=7d

# ==========================================
# تنظیمات سرور
# ==========================================

# پورت سرور بک‌اند
PORT=5000

# روی سرور حتماً production بگذار تا استاتیک فرانت درست سرو شود
NODE_ENV=production

# ==========================================
# تنظیمات CORS (دسترسی از دامنه‌های دیگر)
# ==========================================

# آدرس دقیق فرانت (بدون / آخر). این مبدأ هم به CORS اضافه می‌شود — برای production مثال:
# FRONTEND_URL=https://amlak.mmdcode.top
FRONTEND_URL=http://localhost:5173

# هر دامنهٔ اضافه (با کاما). amlak.mmdcode.top از قبل داخل کد merge می‌شود؛ فقط اگر دامنهٔ دیگری داری بگذار:
# ALLOWED_ORIGINS=https://app.example.com

# محدودیت سراسری درخواست‌ها (Rate Limit)
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=200

# ==========================================
# تنظیمات آپلود فایل
# ==========================================

# حداکثر حجم فایل (به بایت - اینجا 5 مگابایت)
MAX_FILE_SIZE=5242880

# پوشه ذخیره تصاویر
UPLOAD_DIR=uploads

# ==========================================
# اسکریپت seed (scripts/seedDatabase.js)
# ==========================================
# اگر روی سرور پوشه frontend/public/images/properties ندارید، آدرس پایه همان مسیر استاتیک را بدهید
# (بدون / آخر هم OK است). نام فایل‌ها پیش‌فرض مثل download-images: property-01.jpg … property-30.jpg
# SEED_PROPERTY_IMAGES_BASE_URL=https://amlak.mmdcode.top/images/properties
# اختیاری — اگر نام فایل‌های شما فرق دارد، با کاما جدا کنید:
# SEED_PROPERTY_IMAGE_FILENAMES=img1.jpg,img2.jpg,photo-a.png
